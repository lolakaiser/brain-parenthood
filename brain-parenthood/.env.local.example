# Frontend Environment Variables

# API URL (update with your backend URL)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Square Payment Configuration
# Get these from: https://developer.squareup.com/apps

# Square Application ID (for frontend - publicly visible)
NEXT_PUBLIC_SQUARE_APPLICATION_ID=sandbox-sq0idb-YOUR_APPLICATION_ID_HERE

# Square Location ID (for frontend - publicly visible)
NEXT_PUBLIC_SQUARE_LOCATION_ID=YOUR_LOCATION_ID_HERE

# Square Access Token (KEEP SECRET - never expose to frontend)
SQUARE_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE

# Square Environment: 'sandbox' for testing, 'production' for live payments
SQUARE_ENVIRONMENT=sandbox
